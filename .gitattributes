# --- Text files: normalise to LF in the repository so Windows checkouts
# don't introduce CRLF churn (Makefiles in particular break with CRLF). ---
*.py       text eol=lf
*.md       text eol=lf
*.txt      text eol=lf
*.toml     text eol=lf
*.cfg      text eol=lf
*.ini      text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.json     text eol=lf
*.sh       text eol=lf
*.svg      text eol=lf
*.ipynb    text eol=lf
Makefile   text eol=lf
Dockerfile text eol=lf

# --- Binary / Git-LFS-tracked assets ---
*.png filter=lfs diff=lfs merge=lfs -text
*.pdf filter=lfs diff=lfs merge=lfs -text

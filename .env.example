# Copy this file to `.env` and fill in your values.
# `.env` is gitignored — never commit real tokens.

# Required: Hugging Face token (needed for gated models like Llama-3)
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional: Weights & Biases API key for logging reward curves during training
# Get one at https://wandb.ai/authorize
WANDB_API_KEY=

# Optional: override environment server URL (default: http://localhost:7860)
# SERVER_URL=http://localhost:7860

# --- Inference / judge only (not required for training) ---
# OPENAI_API_KEY=
# API_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=meta-llama/Llama-3-8b-instruct

# --- Production server hardening (all optional, off by default) ---
# Require an API key on every API request ("Authorization: Bearer <key>"
# or "X-API-Key: <key>"). Landing pages, /docs and /health stay open.
# SOC_GYM_API_KEY=

# Requests-per-minute cap per client (keyed by API key, else client IP).
# 0 or unset disables rate limiting.
# SOC_GYM_RATE_LIMIT=0

# Multi-session pool: concurrent session cap and idle eviction (seconds).
# Clients pick a session with the X-Session-ID header.
# SOC_GYM_MAX_SESSIONS=64
# SOC_GYM_SESSION_TTL=3600

# Episode audit trail: in-memory window size, plus an optional directory
# for durable JSONL export (one file per episode).
# SOC_GYM_AUDIT_MAX_EPISODES=200
# SOC_GYM_AUDIT_DIR=

# Server bind (defaults suit containers / HF Spaces).
# SOC_TRIAGE_HOST=0.0.0.0
# SOC_TRIAGE_PORT=7860
